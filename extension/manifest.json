{
  "manifest_version": 3,
  "name": "Web Data Scraper",
  "version": "1.0",
  "description": "Extracts structured data from web pages and sends to MongoDB.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}
